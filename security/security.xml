<odoo>
    <data noupdate="0">
        <record id="group_fleet_user" model="res.groups">
            <field name="name">Fleet User</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_fleet_dispatcher" model="res.groups">
            <field name="name">Fleet Dispatcher</field>
            <field name="implied_ids" eval="[(4, ref('mesob_fleet_customizations.group_fleet_user'))]"/>
        </record>

        <record id="group_fleet_manager" model="res.groups">
            <field name="name">Fleet Manager</field>
            <field name="implied_ids" eval="[(4, ref('mesob_fleet_customizations.group_fleet_dispatcher'))]"/>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
        </record>

        <!-- Give all internal users Fleet User access by default -->
        <record id="base.group_user" model="res.groups">
            <field name="implied_ids" eval="[(4, ref('mesob_fleet_customizations.group_fleet_user'))]"/>
        </record>
    </data>
</odoo>
