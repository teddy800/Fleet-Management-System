<odoo>

    <record id="mesob_service_action" model="ir.actions.act_window">
        <field name="name">Service Records</field>
        <field name="res_model">mesob.service.record</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="service_tree" model="ir.ui.view">
        <field name="name">service.tree</field>
        <field name="model">mesob.service.record</field>
        <field name="arch" type="xml">
            <tree>
                <field name="vehicle_id"/>
                <field name="service_type"/>
                <field name="date"/>
                <field name="cost"/>
            </tree>
        </field>
    </record>

    <record id="service_form" model="ir.ui.view">
        <field name="name">service.form</field>
        <field name="model">mesob.service.record</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="vehicle_id"/>
                        <field name="service_type"/>
                        <field name="date"/>
                        <field name="cost"/>
                        <field name="fuel_volume"/>
                        <field name="odometer"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>