<odoo>
    <record id="view_service_record_form" model="ir.ui.view">
        <field name="name">mesob.service.record.form</field>
        <field name="model">mesob.service.record</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="vehicle_id" required="1"/>
                            <field name="date"/>
                            <field name="service_type" widget="selection"/>
                            <field name="odometer"/>
                        </group>
                        <group>
                            <field name="cost"/>
                            <field name="fuel_volume"/>
                        </group>
                    </group>
                    <field name="description" placeholder="Service description..."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_service_record_list" model="ir.ui.view">
        <field name="name">mesob.service.record.list</field>
        <field name="model">mesob.service.record</field>
        <field name="arch" type="xml">
            <list>
                <field name="vehicle_id"/>
                <field name="date"/>
                <field name="service_type"/>
                <field name="cost"/>
                <field name="odometer"/>
            </list>
        </field>
    </record>

    <record id="action_service_records" model="ir.actions.act_window">
        <field name="name">Service Records</field>
        <field name="res_model">mesob.service.record</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
