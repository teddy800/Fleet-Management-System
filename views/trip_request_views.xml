<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_trip_request_list" model="ir.ui.view">
        <field name="name">mesob.trip.request.list</field>
        <field name="model">mesob.trip.request</field>
        <field name="arch" type="xml">
            <list>
                <field name="vehicle_id"/>
                <field name="driver_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_trip_request_form" model="ir.ui.view">
        <field name="name">mesob.trip.request.form</field>
        <field name="model">mesob.trip.request</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button string="Approve" name="action_approve" type="object"
                            invisible="state != 'draft'" class="btn-primary"/>
                    <button string="Mark Done" name="action_done" type="object"
                            invisible="state != 'approved'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,approved,done"/>
                </header>
                <sheet>
                    <group>
                        <field name="vehicle_id"/>
                        <field name="driver_id"/>
                        <field name="start_date"/>
                        <field name="end_date"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_trip_request" model="ir.actions.act_window">
        <field name="name">Trip Requests</field>
        <field name="res_model">mesob.trip.request</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
