<odoo>
    <!-- Form View -->
    <record id="view_trip_request_form" model="ir.ui.view">
        <field name="name">mesob.trip.request.form</field>
        <field name="model">mesob.trip.request</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit" string="Submit" type="object"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_approve" string="Approve" type="object"
                            class="btn-success" invisible="state != 'pending'"
                            groups="mesob_fleet_customizations.group_fleet_dispatcher"/>
                    <button name="action_reject" string="Reject" type="object"
                            class="btn-danger" invisible="state != 'pending'"
                            groups="mesob_fleet_customizations.group_fleet_dispatcher"/>
                    <button name="action_cancel" string="Cancel" type="object"
                            invisible="state not in ('draft','pending')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,pending,approved,assigned,in_progress,completed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Request Details">
                            <field name="employee_id" options="{'no_create': True}"/>
                            <field name="purpose"/>
                            <field name="vehicle_category"/>
                            <field name="trip_type"/>
                            <field name="priority" widget="priority"/>
                            <field name="passenger_count"/>
                        </group>
                        <group string="Schedule">
                            <field name="start_datetime"/>
                            <field name="end_datetime"/>
                            <field name="duration_hours" readonly="1"/>
                            <field name="is_recurring"/>
                        </group>
                    </group>
                    <group string="Locations">
                        <field name="pickup_location"/>
                        <field name="destination_location"/>
                        <field name="estimated_distance"/>
                        <field name="estimated_duration"/>
                    </group>
                    <group string="Assignment" invisible="state in ('draft','pending')">
                        <field name="assigned_vehicle_id" readonly="1"/>
                        <field name="assigned_driver_id" readonly="1"/>
                        <field name="approved_by" readonly="1"/>
                        <field name="approved_date" readonly="1"/>
                    </group>
                    <group string="Rejection" invisible="state != 'rejected'">
                        <field name="rejection_reason" readonly="1"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- List View -->
    <record id="view_trip_request_list" model="ir.ui.view">
        <field name="name">mesob.trip.request.list</field>
        <field name="model">mesob.trip.request</field>
        <field name="arch" type="xml">
            <list string="Trip Requests" decoration-info="state == 'pending'"
                  decoration-success="state == 'approved'"
                  decoration-warning="state == 'in_progress'"
                  decoration-muted="state in ('completed','cancelled')">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="vehicle_category"/>
                <field name="start_datetime"/>
                <field name="end_datetime"/>
                <field name="pickup_location"/>
                <field name="destination_location"/>
                <field name="priority" widget="priority"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'pending'"
                       decoration-success="state in ('approved','assigned')"
                       decoration-warning="state == 'in_progress'"/>
            </list>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_trip_request_search" model="ir.ui.view">
        <field name="name">mesob.trip.request.search</field>
        <field name="model">mesob.trip.request</field>
        <field name="arch" type="xml">
            <search string="Trip Requests">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="vehicle_category"/>
                <filter string="My Requests" name="my_requests"
                        domain="[('employee_id.user_id','=',uid)]"/>
                <filter string="Pending" name="pending" domain="[('state','=','pending')]"/>
                <filter string="Approved" name="approved" domain="[('state','=','approved')]"/>
                <filter string="In Progress" name="in_progress" domain="[('state','=','in_progress')]"/>
                <separator/>
                <filter string="By Status" name="group_state" context="{'group_by':'state'}"/>
                <filter string="By Requester" name="group_employee" context="{'group_by':'employee_id'}"/>
                <filter string="By Category" name="group_category" context="{'group_by':'vehicle_category'}"/>
            </search>
        </field>
    </record>

    <!-- Dispatcher Queue Action -->
    <record id="action_dispatcher_queue" model="ir.actions.act_window">
        <field name="name">Dispatcher Queue</field>
        <field name="res_model">mesob.trip.request</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state','=','pending')]</field>
        <field name="context">{}</field>
    </record>

    <!-- My Trip Requests Action -->
    <record id="action_my_trip_requests" model="ir.actions.act_window">
        <field name="name">My Trip Requests</field>
        <field name="res_model">mesob.trip.request</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('employee_id.user_id','=',uid)]</field>
        <field name="context">{}</field>
    </record>

    <!-- All Trip Requests Action -->
    <record id="action_trip_requests" model="ir.actions.act_window">
        <field name="name">All Trip Requests</field>
        <field name="res_model">mesob.trip.request</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
    </record>
</odoo>
