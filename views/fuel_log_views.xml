<odoo>
    <record id="view_fuel_log_form" model="ir.ui.view">
        <field name="name">mesob.fuel.log.form</field>
        <field name="model">mesob.fuel.log</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group string="Refuel Details">
                            <field name="vehicle_id" required="1"/>
                            <field name="driver_id"/>
                            <field name="date" required="1"/>
                            <field name="fuel_station"/>
                        </group>
                        <group string="Quantities">
                            <field name="volume"/>
                            <field name="cost"/>
                            <field name="odometer"/>
                            <field name="efficiency" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_fuel_log_list" model="ir.ui.view">
        <field name="name">mesob.fuel.log.list</field>
        <field name="model">mesob.fuel.log</field>
        <field name="arch" type="xml">
            <list>
                <field name="vehicle_id"/>
                <field name="driver_id"/>
                <field name="date"/>
                <field name="fuel_station"/>
                <field name="volume"/>
                <field name="cost"/>
                <field name="odometer"/>
                <field name="efficiency"/>
            </list>
        </field>
    </record>

    <record id="action_fuel_logs" model="ir.actions.act_window">
        <field name="name">Fuel Logs</field>
        <field name="res_model">mesob.fuel.log</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
