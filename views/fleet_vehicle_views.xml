<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_mesob_vehicles" model="ir.actions.act_window">
        <field name="name">Vehicles</field>
        <field name="res_model">fleet.vehicle</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="context">{}</field>
    </record>

    <record id="fleet_vehicle_form_mesob" model="ir.ui.view">
        <field name="name">fleet.vehicle.form.mesob</field>
        <field name="model">fleet.vehicle</field>
        <field name="inherit_id" ref="fleet.fleet_vehicle_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="MESSOB Fleet Info">
                    <field name="mesob_status"/>
                    <field name="mesob_vehicle_category"/>
                    <field name="current_odometer"/>
                    <field name="assigned_driver_id"/>
                    <field name="insurance_expiry"/>
                    <field name="registration_expiry"/>
                </group>
                <notebook>
                    <page string="Live GPS Location" name="gps_location">
                        <group>
                            <group string="Current Position">
                                <field name="current_latitude" readonly="1"/>
                                <field name="current_longitude" readonly="1"/>
                                <field name="current_speed" readonly="1"/>
                                <field name="current_heading" readonly="1"/>
                                <field name="gps_accuracy" readonly="1"/>
                                <field name="last_gps_update" readonly="1"/>
                            </group>
                            <group string="Fleet Metrics">
                                <field name="fuel_efficiency" readonly="1"/>
                                <field name="utilization_rate" readonly="1"/>
                                <field name="total_trips" readonly="1"/>
                                <field name="total_maintenance_cost" readonly="1"/>
                                <field name="maintenance_due" readonly="1"/>
                            </group>
                        </group>
                        <field name="gps_map_url" invisible="1"/>
                        <div invisible="not gps_map_url" style="margin-top:8px;">
                            <h4 style="margin-bottom:4px;">Live Vehicle Location</h4>
                            <field name="gps_map_url" widget="url" string="Open in OpenStreetMap"/>
                        </div>
                        <div invisible="gps_map_url" class="alert alert-info" style="margin-top:8px;">
                            No GPS data yet. Location will appear once the vehicle starts transmitting.
                        </div>
                    </page>
                    <page string="GPS History" name="gps_history">
                        <p class="text-muted">
                            View full GPS history via Tracking → GPS Logs, filtered by this vehicle.
                        </p>
                    </page>
                </notebook>
            </xpath>
        </field>
    </record>
</odoo>
