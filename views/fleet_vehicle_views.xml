<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="fleet_vehicle_form_mesob" model="ir.ui.view">
        <field name="name">fleet.vehicle.form.mesob</field>
        <field name="model">fleet.vehicle</field>
        <field name="inherit_id" ref="fleet.fleet_vehicle_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="MESSOB Fleet Info" col="2">
                    <field name="mesob_vehicle_category"/>
                    <field name="availability"/>
                    <field name="maintenance_due" readonly="1"/>
                    <field name="current_odometer"/>
                    <field name="assigned_driver_id"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
