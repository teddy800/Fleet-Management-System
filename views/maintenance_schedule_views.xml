<odoo>
    <record id="view_maintenance_schedule_form" model="ir.ui.view">
        <field name="name">mesob.maintenance.schedule.form</field>
        <field name="model">mesob.maintenance.schedule</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="vehicle_id" required="1"/>
                        <field name="interval_km"/>
                        <field name="last_odometer"/>
                        <field name="last_service_date"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_maintenance_schedule_list" model="ir.ui.view">
        <field name="name">mesob.maintenance.schedule.list</field>
        <field name="model">mesob.maintenance.schedule</field>
        <field name="arch" type="xml">
            <list>
                <field name="vehicle_id"/>
                <field name="interval_km"/>
                <field name="last_odometer"/>
                <field name="last_service_date"/>
            </list>
        </field>
    </record>

    <record id="action_maintenance_schedules" model="ir.actions.act_window">
        <field name="name">Maintenance Schedules</field>
        <field name="res_model">mesob.maintenance.schedule</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
