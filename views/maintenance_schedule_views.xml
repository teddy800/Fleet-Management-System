<odoo>
    <record id="view_maintenance_schedule_form" model="ir.ui.view">
        <field name="name">mesob.maintenance.schedule.form</field>
        <field name="model">mesob.maintenance.schedule</field>
        <field name="arch" type="xml">
            <form string="Maintenance Schedule">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="display_name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Vehicle &amp; Type">
                            <field name="vehicle_id"/>
                            <field name="maintenance_type"/>
                        </group>
                        <group string="Schedule Intervals">
                            <field name="interval_km"/>
                            <field name="interval_days"/>
                        </group>
                    </group>
                    <group>
                        <group string="Last Service">
                            <field name="last_odometer"/>
                            <field name="last_service_date"/>
                        </group>
                        <group string="Next Due (Auto-computed)">
                            <field name="next_due_odometer" readonly="1"/>
                            <field name="next_due_date" readonly="1"/>
                            <field name="is_overdue" readonly="1"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1" colspan="2"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_maintenance_schedule_list" model="ir.ui.view">
        <field name="name">mesob.maintenance.schedule.list</field>
        <field name="model">mesob.maintenance.schedule</field>
        <field name="arch" type="xml">
            <list decoration-danger="is_overdue == True">
                <field name="vehicle_id"/>
                <field name="maintenance_type"/>
                <field name="interval_km"/>
                <field name="interval_days"/>
                <field name="last_odometer"/>
                <field name="last_service_date"/>
                <field name="next_due_date"/>
                <field name="next_due_odometer"/>
                <field name="is_overdue" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="action_maintenance_schedules" model="ir.actions.act_window">
        <field name="name">Maintenance Schedules</field>
        <field name="res_model">mesob.maintenance.schedule</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
