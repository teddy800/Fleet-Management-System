<odoo>
    <record id="view_trip_assignment_form" model="ir.ui.view">
        <field name="name">mesob.trip.assignment.form</field>
        <field name="model">mesob.trip.assignment</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" string="Confirm Assignment" type="object"
                            class="btn-primary" invisible="state != 'draft'"
                            groups="mesob_fleet_customizations.group_fleet_dispatcher"/>
                    <button name="action_cancel" string="Cancel" type="object"
                            invisible="state == 'cancelled'"
                            groups="mesob_fleet_customizations.group_fleet_dispatcher"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,assigned,in_progress,completed,cancelled"/>
                </header>
                <sheet>
                    <group>
                        <field name="trip_request_id"/>
                        <field name="vehicle_id" domain="[]"/>
                        <field name="driver_id" domain="[('active','=',True)]"/>
                        <field name="start_datetime" readonly="1"/>
                        <field name="stop_datetime" readonly="1"/>
                        <field name="confirmed_at" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_trip_assignment_list" model="ir.ui.view">
        <field name="name">mesob.trip.assignment.list</field>
        <field name="model">mesob.trip.assignment</field>
        <field name="arch" type="xml">
            <list string="Fleet Availability">
                <field name="vehicle_id"/>
                <field name="driver_id"/>
                <field name="trip_request_id"/>
                <field name="start_datetime"/>
                <field name="stop_datetime"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'assigned'"
                       decoration-info="state == 'in_progress'"
                       decoration-muted="state == 'completed'"
                       decoration-warning="state == 'draft'"
                       decoration-danger="state == 'cancelled'"/>
                <field name="confirmed_at"/>
            </list>
        </field>
    </record>

    <!-- FR-2.3: Fleet Availability Calendar View -->
    <record id="view_trip_assignment_calendar" model="ir.ui.view">
        <field name="name">mesob.trip.assignment.calendar</field>
        <field name="model">mesob.trip.assignment</field>
        <field name="arch" type="xml">
            <calendar string="Fleet Availability"
                      date_start="start_datetime"
                      date_stop="stop_datetime"
                      color="vehicle_id"
                      mode="week"
                      quick_create="false">
                <field name="vehicle_id"/>
                <field name="driver_id"/>
                <field name="state"/>
            </calendar>
        </field>
    </record>

    <!-- FR-2.3: Fleet Availability Action with calendar + list + form -->
    <record id="action_trip_assignments" model="ir.actions.act_window">
        <field name="name">Fleet Availability</field>
        <field name="res_model">mesob.trip.assignment</field>
        <field name="view_mode">calendar,list,form</field>
        <field name="context">{'search_default_confirmed': 1}</field>
    </record>

    <!-- Search view with filters -->
    <record id="view_trip_assignment_search" model="ir.ui.view">
        <field name="name">mesob.trip.assignment.search</field>
        <field name="model">mesob.trip.assignment</field>
        <field name="arch" type="xml">
            <search string="Fleet Availability">
                <field name="vehicle_id"/>
                <field name="driver_id"/>
                <filter string="Assigned" name="confirmed" domain="[('state','=','assigned')]"/>
                <filter string="In Progress" name="in_progress" domain="[('state','=','in_progress')]"/>
                <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
                <separator/>
                <filter string="By Vehicle" name="group_vehicle" context="{'group_by':'vehicle_id'}"/>
                <filter string="By Driver" name="group_driver" context="{'group_by':'driver_id'}"/>
            </search>
        </field>
    </record>
</odoo>
