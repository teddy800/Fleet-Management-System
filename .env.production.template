# MESSOB Fleet Management - Production Environment Configuration
# Copy this file to .env.production and update with your actual values

# ═══════════════════════════════════════════════════════════════════════════════
# 🔐 SECURITY CONFIGURATION (CRITICAL - CHANGE ALL DEFAULTS)
# ═══════════════════════════════════════════════════════════════════════════════

# Strong admin password (minimum 16 characters, mixed case, numbers, symbols)
ADMIN_PASSWORD=YourSecureAdminPassword123!@#

# Database credentials (NEVER use default passwords in production)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=messob_fleet_prod
DB_USER=messob_fleet_user
DB_PASSWORD=YourSecureDatabasePassword456!@#

# Domain configuration
DOMAIN_NAME=fleet.messob.org
ENVIRONMENT=production

# ═══════════════════════════════════════════════════════════════════════════════
# 🌐 EXTERNAL INTEGRATIONS
# ═══════════════════════════════════════════════════════════════════════════════

# HR System Integration
HR_SYNC_URL=https://hr.messob.org/api/employees
HR_API_KEY=your-hr-system-api-key-here
HR_SYNC_ENABLED=true

# GPS Tracking Integration
GPS_WEBHOOK_URL=https://fleet.messob.org/webhook/gps/location-update
GPS_API_KEY=your-gps-provider-api-key-here
GPS_PROVIDER_URL=https://gps-provider.com/api/vehicles

# Email Notifications (SendGrid, AWS SES, etc.)
EMAIL_PROVIDER=sendgrid
EMAIL_API_KEY=your-email-api-key-here
EMAIL_FROM_ADDRESS=noreply@messob.org
EMAIL_FROM_NAME=MESSOB Fleet Management

# SMS Notifications (optional)
SMS_PROVIDER=twilio
SMS_API_KEY=your-sms-api-key-here
SMS_FROM_NUMBER=+1234567890

# ═══════════════════════════════════════════════════════════════════════════════
# 🚀 PERFORMANCE & SCALING
# ═══════════════════════════════════════════════════════════════════════════════

# Odoo Workers (CPU cores * 2 + 1)
WORKERS=4
MAX_CRON_THREADS=2

# Memory Limits (in bytes)
MEMORY_LIMIT_HARD=2684354560  # 2.5GB
MEMORY_LIMIT_SOFT=2147483648  # 2GB

# Session Configuration
SESSION_TIMEOUT=3600  # 1 hour

# Database Connection Pool
DB_MAXCONN=64

# ═══════════════════════════════════════════════════════════════════════════════
# 📊 MONITORING & LOGGING
# ═══════════════════════════════════════════════════════════════════════════════

# Log Level (debug, info, warn, error, critical)
LOG_LEVEL=info

# Monitoring
HEALTH_CHECK_ENABLED=true
METRICS_ENABLED=true

# External Monitoring (optional)
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090

GRAFANA_ENABLED=false
GRAFANA_PORT=3000

# Log Aggregation (ELK Stack)
ELASTICSEARCH_URL=http://localhost:9200
KIBANA_URL=http://localhost:5601

# ═══════════════════════════════════════════════════════════════════════════════
# 🔒 SSL/TLS CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# SSL Certificate Paths (update with your actual certificate paths)
SSL_CERT_PATH=/etc/ssl/certs/messob-fleet.crt
SSL_KEY_PATH=/etc/ssl/private/messob-fleet.key

# Let's Encrypt (if using certbot)
LETSENCRYPT_EMAIL=admin@messob.org
LETSENCRYPT_ENABLED=false

# ═══════════════════════════════════════════════════════════════════════════════
# 💾 BACKUP CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# Backup Settings
BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE="0 2 * * *"  # Daily at 2 AM

# Remote Backup (AWS S3, Google Cloud, etc.)
REMOTE_BACKUP_ENABLED=false
REMOTE_BACKUP_PROVIDER=aws_s3
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=messob-fleet-backups
AWS_REGION=us-east-1

# ═══════════════════════════════════════════════════════════════════════════════
# 🛡️ SECURITY HARDENING
# ═══════════════════════════════════════════════════════════════════════════════

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_LOGIN_ATTEMPTS=5

# CORS Configuration
CORS_ENABLED=true
CORS_ALLOWED_ORIGINS=https://fleet.messob.org

# Security Headers
SECURITY_HEADERS_ENABLED=true
HSTS_MAX_AGE=31536000

# Fail2Ban Integration
FAIL2BAN_ENABLED=true
FAIL2BAN_MAX_RETRY=5
FAIL2BAN_BAN_TIME=3600

# ═══════════════════════════════════════════════════════════════════════════════
# 🔧 MAINTENANCE & UPDATES
# ═══════════════════════════════════════════════════════════════════════════════

# Maintenance Mode
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE="System is under maintenance. Please try again later."

# Auto Updates
AUTO_UPDATES_ENABLED=false
UPDATE_SCHEDULE="0 3 * * 0"  # Weekly on Sunday at 3 AM

# ═══════════════════════════════════════════════════════════════════════════════
# 📱 MOBILE & API CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# API Configuration
API_VERSION=v1
API_RATE_LIMIT=1000  # requests per hour per user

# Mobile App Configuration
MOBILE_APP_VERSION=1.0.0
MOBILE_FORCE_UPDATE=false

# Push Notifications (Firebase, etc.)
PUSH_NOTIFICATIONS_ENABLED=false
FIREBASE_SERVER_KEY=your-firebase-server-key
FIREBASE_PROJECT_ID=your-firebase-project-id

# ═══════════════════════════════════════════════════════════════════════════════
# 🌍 LOCALIZATION
# ═══════════════════════════════════════════════════════════════════════════════

# Default Language
DEFAULT_LANGUAGE=en_US
SUPPORTED_LANGUAGES=en_US,am_ET

# Timezone
DEFAULT_TIMEZONE=Africa/Addis_Ababa

# Currency
DEFAULT_CURRENCY=ETB

# ═══════════════════════════════════════════════════════════════════════════════
# 🧪 TESTING & DEVELOPMENT
# ═══════════════════════════════════════════════════════════════════════════════

# Testing Configuration (set to false in production)
DEMO_DATA_ENABLED=false
DEBUG_MODE=false
TEST_MODE=false

# Development Tools (disable in production)
PROFILER_ENABLED=false
SQL_DEBUG=false

# ═══════════════════════════════════════════════════════════════════════════════
# 📈 ANALYTICS & REPORTING
# ═══════════════════════════════════════════════════════════════════════════════

# Analytics
ANALYTICS_ENABLED=true
GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X

# Reporting
REPORT_GENERATION_ENABLED=true
REPORT_RETENTION_DAYS=90

# Business Intelligence
BI_DASHBOARD_ENABLED=false
BI_REFRESH_INTERVAL=3600  # 1 hour

# ═══════════════════════════════════════════════════════════════════════════════
# 🔗 THIRD-PARTY INTEGRATIONS
# ═══════════════════════════════════════════════════════════════════════════════

# Mapping Services
MAPS_PROVIDER=google
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
MAPBOX_ACCESS_TOKEN=your-mapbox-access-token

# Weather Services (for route planning)
WEATHER_API_ENABLED=false
WEATHER_API_KEY=your-weather-api-key

# Fuel Price APIs
FUEL_PRICE_API_ENABLED=false
FUEL_PRICE_API_KEY=your-fuel-price-api-key

# ═══════════════════════════════════════════════════════════════════════════════
# 💰 BILLING & COST TRACKING
# ═══════════════════════════════════════════════════════════════════════════════

# Cost Tracking
COST_TRACKING_ENABLED=true
COST_CENTER_INTEGRATION=false

# Budget Alerts
BUDGET_ALERTS_ENABLED=true
BUDGET_THRESHOLD_WARNING=80  # Percentage
BUDGET_THRESHOLD_CRITICAL=95  # Percentage

# ═══════════════════════════════════════════════════════════════════════════════
# 🚨 ALERTING & NOTIFICATIONS
# ═══════════════════════════════════════════════════════════════════════════════

# System Alerts
SYSTEM_ALERTS_ENABLED=true
ALERT_EMAIL_RECIPIENTS=admin@messob.org,it@messob.org

# Maintenance Alerts
MAINTENANCE_ALERTS_ENABLED=true
MAINTENANCE_ALERT_DAYS_ADVANCE=7

# Fuel Alerts
FUEL_ALERTS_ENABLED=true
FUEL_LOW_THRESHOLD=20  # Percentage

# GPS Alerts
GPS_ALERTS_ENABLED=true
GPS_OFFLINE_THRESHOLD=300  # 5 minutes

# ═══════════════════════════════════════════════════════════════════════════════
# 🏢 ORGANIZATION SETTINGS
# ═══════════════════════════════════════════════════════════════════════════════

# Organization Details
ORG_NAME=MESSOB
ORG_ADDRESS="Addis Ababa, Ethiopia"
ORG_PHONE="+251-11-XXX-XXXX"
ORG_EMAIL=info@messob.org
ORG_WEBSITE=https://messob.org

# Business Hours
BUSINESS_HOURS_START=08:30
BUSINESS_HOURS_END=17:30
BUSINESS_DAYS=monday,tuesday,wednesday,thursday

# Emergency Contacts
EMERGENCY_CONTACT_1="+251-91-XXX-XXXX"
EMERGENCY_CONTACT_2="+251-92-XXX-XXXX"